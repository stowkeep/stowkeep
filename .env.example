# Example environment variables for local development.
# Copy to .env in the repository root: cp .env.example .env

# --- Database (pick one) ---

# SQLite (default — no external DB)
STOWKEEP_DATABASE_DRIVER=sqlite
STOWKEEP_DATABASE_PATH=./.data/dev.db

# PostgreSQL (production-like local dev)
# STOWKEEP_DATABASE_DRIVER=postgres
# STOWKEEP_DATABASE_URL=postgres://stowkeep:stowkeep@localhost:5432/stowkeep?sslmode=disable

# --- Server ---
STOWKEEP_HTTP_ADDR=:8080
STOWKEEP_MIGRATIONS_DIR=migrations
STOWKEEP_LOG_LEVEL=debug
STOWKEEP_LOG_FORMAT=text

# --- Feature flags (Stage 1+) ---
STOWKEEP_FEATURES=swarm_readonly,stack_deploy

# --- Session ---
# STOWKEEP_SESSION_IDLE_TTL=24h
# STOWKEEP_COOKIE_SECURE=false

# --- Docker ---
STOWKEEP_DOCKER_HOST=unix:///var/run/docker.sock
# STOWKEEP_DOCKER_TIMEOUT=30s
